DATAFORSEO_LOGIN=your_login_here
DATAFORSEO_PASSWORD=your_password_here

SERPAPI_API_KEY=your_serpapi_key_here

# Google Search Console (OAuth2 refresh token flow - never expires)
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here
GOOGLE_REFRESH_TOKEN=your_refresh_token_here
GA4_PROPERTY_ID=your_ga4_property_id_here

# Microsoft Clarity (Data Export API)
CLARITY_API_TOKEN=your_clarity_api_token_here

# Google PageSpeed Insights
PAGESPEED_API_KEY=your_pagespeed_api_key_here

# DNA Music dashboard targets
DNA_SITE_CO=sc-domain:dnamusic.edu.co
DNA_SITE_MX=sc-domain:dnamusic.mx
DNA_DOMAIN_CO=dnamusic.edu.co
DNA_DOMAIN_MX=dnamusic.mx
DNA_CANONICAL_URL=https://www.dnamusic.edu.co/
DNA_INSPECTION_URL=https://www.dnamusic.edu.co/
DNA_LOCATION_CO=2170
DNA_LOCATION_MX=2484

# Optional Neon Postgres persistence for dashboard snapshots
DATABASE_URL=postgres://user:password@host/database?sslmode=require

# Optional premium SEO connectors
AHREFS_API_TOKEN=your_ahrefs_api_token_here
SEMRUSH_API_KEY=your_semrush_api_key_here
